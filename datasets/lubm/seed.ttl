# Bench seed for the LUBM-1 cell.
#
# Originally LUBM-only (5 graduate students enrolled in a course;
# sufficient for `lubm-q1` and `spo`). Extended 2026-05-04 with a
# minimal set of VC + BSBM fixtures so the cross-class bench cells
# (`bgp/employment-status`, `filter/can-drive`, `filter/numeric-range`)
# also produce real numbers against the bootstrap dataset.
#
# Real LUBM-1 is generated by `node lubm.js` under build.sh; this
# seed is the in-memory fallback used when no `dist/lubm/` is
# present. See `harness/dataset-loader.js`.

@prefix rdf:           <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd:           <http://www.w3.org/2001/XMLSchema#> .
@prefix ub:            <http://www.lehigh.edu/~zhp2/2004/0401/univ-bench.owl#> .
@prefix dpt:           <http://www.Department0.University0.edu/> .
@prefix schema:        <http://schema.org/> .
@prefix citizenship:   <https://w3id.org/citizenship#> .
@prefix vdl:           <https://w3id.org/vdl#> .
@prefix bsbm:          <http://www4.wiwiss.fu-berlin.de/bizer/bsbm/v01/vocabulary/> .
@prefix ex:            <urn:zksparql-bench:ex:> .

# ---------------------------------------------------------------
# LUBM fragment — covers `bgp/lubm-q1` + `bgp/spo`.
# ---------------------------------------------------------------

dpt:GraduateStudent0 a ub:GraduateStudent ;
  ub:takesCourse dpt:GraduateCourse0 .

dpt:GraduateStudent1 a ub:GraduateStudent ;
  ub:takesCourse dpt:GraduateCourse0 .

dpt:GraduateStudent2 a ub:GraduateStudent ;
  ub:takesCourse dpt:GraduateCourse1 .

dpt:GraduateStudent3 a ub:UndergraduateStudent ;
  ub:takesCourse dpt:GraduateCourse0 .

dpt:GraduateStudent4 a ub:GraduateStudent ;
  ub:takesCourse dpt:GraduateCourse0 .

# ---------------------------------------------------------------
# VC fragment — covers `bgp/employment-status` + `filter/can-drive`.
# Two persons; each holds a residence record + an EAD with the
# C09 lprCategory the can-drive query gates on; one also holds
# a vdl license with an expiry date inside the 2025+ window.
# ---------------------------------------------------------------

ex:alice a citizenship:EmployablePerson ;
  schema:givenName  "Alice" ;
  schema:familyName "Anders" ;
  schema:birthDate  "1990-01-01T00:00:00"^^xsd:dateTime ;
  citizenship:residentSince "2015-06-01T00:00:00"^^xsd:dateTime ;
  citizenship:employmentAuthorizationDocument [
    citizenship:lprCategory "C09" ;
  ] ;
  vdl:license [
    vdl:expiryDate "2027-04-30T00:00:00"^^xsd:dateTime ;
  ] .

ex:bob a citizenship:EmployablePerson ;
  schema:givenName  "Bob" ;
  schema:familyName "Brown" ;
  schema:birthDate  "1985-03-15T00:00:00"^^xsd:dateTime ;
  citizenship:residentSince "2018-09-12T00:00:00"^^xsd:dateTime ;
  citizenship:employmentAuthorizationDocument [
    citizenship:lprCategory "C09" ;
  ] ;
  vdl:license [
    vdl:expiryDate "2026-11-15T00:00:00"^^xsd:dateTime ;
  ] .

# ---------------------------------------------------------------
# BSBM fragment — covers `filter/numeric-range`.
# Two products with one numeric property; one passes the >100 filter.
# ---------------------------------------------------------------

ex:product1 a bsbm:Product ;
  bsbm:productPropertyNumeric1 150 .

ex:product2 a bsbm:Product ;
  bsbm:productPropertyNumeric1 50 .
