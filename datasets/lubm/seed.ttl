# Tiny LUBM-shaped seed for the bootstrap cell.
# 5 graduate students enrolled in a course; sufficient for LUBM Q1 BGP.
# Real LUBM-1 is generated by `node lubm.js` under build.sh.

@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix ub:  <http://www.lehigh.edu/~zhp2/2004/0401/univ-bench.owl#> .
@prefix dpt: <http://www.Department0.University0.edu/> .

dpt:GraduateStudent0 a ub:GraduateStudent ;
  ub:takesCourse dpt:GraduateCourse0 .

dpt:GraduateStudent1 a ub:GraduateStudent ;
  ub:takesCourse dpt:GraduateCourse0 .

dpt:GraduateStudent2 a ub:GraduateStudent ;
  ub:takesCourse dpt:GraduateCourse1 .

dpt:GraduateStudent3 a ub:UndergraduateStudent ;
  ub:takesCourse dpt:GraduateCourse0 .

dpt:GraduateStudent4 a ub:GraduateStudent ;
  ub:takesCourse dpt:GraduateCourse0 .
