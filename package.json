{
  "name": "zksparql-bench",
  "version": "1.3.0",
  "description": "A benchmark for zero knowledge SPARQL queries over Verifiable Credentials",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "build": "bash ./build.sh",
    "semantic-release": "semantic-release",
    "vc-cli": "vc-cli",
    "collect": "vc-cli collect -d ./dist/bsbm/data-signed/ -o bsbm.ttl --document-loader-content='./dist/context.json'",
    "canonize": "node ./canonize.js",
    "transform": "node ./transform.js",
    "sp2b:fetch-run": "bash ./scripts/sp2b-fetch-run.sh",
    "sp2b:vc": "node ./sp2b.js",
    "sp2b:queries": "node ./scripts/sp2b-fetch-queries.js",
    "bench:enumerate": "node ./harness/run-axis.js --enumerate-only",
    "bench:bootstrap": "node ./harness/run-axis.js --bootstrap --out results/local-bootstrap.json",
    "bench:report": "node ./analysis/report.js results/local-bootstrap.json --out analysis/out/table-8.3.tex"
  },
  "bin": {
    "canonize": "node ./canonize.js",
    "transform": "node ./transform.js"
  },
  "keywords": [],
  "author": "Jesse Wright <https://github.com/jeswr>",
  "files": [
    "dist",
    "worker.js",
    "canonize.js",
    "transform.js",
    "frame.js",
    "scripts"
  ],
  "license": "MIT",
  "dependencies": {
    "@jeswr/vc-cli": "^1.20.0",
    "asynciterator": "^3.9.0",
    "jsonld": "^8.3.3",
    "n3": "^1.25.2",
    "rdf-dereference": "^4.0.0",
    "rdf-dereference-store": "^1.3.2",
    "rdf-namespaces": "^1.12.0"
  },
  "optionalDependencies": {
    "@jeswr/sparql-noir": "*"
  },
  "devDependencies": {
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^9.2.6",
    "@semantic-release/npm": "^11.0.2",
    "semantic-release": "^22.0.7"
  },
  "release": {
    "branches": [
      "main"
    ],
    "plugins": [
      "@semantic-release/commit-analyzer",
      "@semantic-release/release-notes-generator",
      "@semantic-release/npm",
      "@semantic-release/github",
      "@semantic-release/git"
    ]
  }
}
